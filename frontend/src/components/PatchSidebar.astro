---
import Link from '@/components/Link.astro'
import { ScrollArea } from '@/components/ui/scroll-area'
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'

interface Props {
  patches: string[]
  activePatch: string
  latest: string
  className?: string
}

const { patches, activePatch, latest, className } = Astro.props
---

<div
  id="patch-sidebar-container"
  class={cn(
    'sticky top-20 col-start-3 row-span-1 mr-auto ml-8 hidden h-[calc(100vh-5rem)] max-w-md lg:block',
    className,
  )}
>
  <ScrollArea
    client:load
    className="flex max-h-[calc(100vh-8rem)] flex-col overflow-y-auto"
  >
    <div class="px-4">
      <div class="mb-4 text-xs font-semibold uppercase tracking-widest text-muted-foreground/60">
        Patch History
      </div>
      <ul class="space-y-1">
        {
          patches.map((patch) => {
            const isActive = patch === activePatch
            const href = patch === latest ? '/tierlist' : `/tierlist/${patch}`

            return (
              <li>
                <Link
                  href={href}
                  class={cn(
                    'flex items-center gap-2 rounded-md px-3 py-2 text-sm transition-colors',
                    isActive
                      ? 'bg-muted font-medium text-foreground'
                      : 'text-muted-foreground hover:bg-muted/50 hover:text-foreground',
                  )}
                >
                  <Icon
                    name={isActive ? 'lucide:file-check' : 'lucide:file-clock'}
                    class={cn('size-4 shrink-0', isActive ? 'text-primary' : 'opacity-50')}
                  />
                  <span>Patch {patch}</span>
                  {patch === latest && (
                    <span class="ml-auto text-[10px] font-bold uppercase tracking-tight text-primary/80">Latest</span>
                  )}
                </Link>
              </li>
            )
          })
        }
      </ul>
    </div>
  </ScrollArea>
</div>