---
---

<header class="flex items-center justify-between px-4 py-2 text-sm font-medium">
  <!-- Left: Set selector -->
  <div class="flex items-center gap-3">
    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-[#2a3a50] hover:bg-muted/50 transition-colors duration-300 ease-in-out">
      <span class="text-sm font-semibold tracking-wide">Set 17</span>
      <svg class="w-3.5 h-3.5 text-[#8a9bb0]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
  </div>

  <!-- Center: Toggles + Actions -->
  <div class="flex items-center gap-2">

    <!-- Names toggle -->
    <label class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-[#2a3a50] cursor-pointer select-none">
      <span class="text-xs">Names</span>
      <div class="relative w-9 h-5">
        <input type="checkbox" class="sr-only peer" checked />
        <div class="w-9 h-5 rounded-full bg-[#1e2d3d] peer-checked:bg-amber-500 transition-colors duration-200"></div>
        <div class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-white shadow peer-checked:translate-x-4 transition-transform duration-200"></div>
      </div>
    </label>

    <div class="w-px h-5  mx-1" />

    <!-- Undo / Redo / Clear -->
    <button class="px-3 py-1.5 text-xs  border rounded-lg hover:bg-muted/50 transition-colors">Undo</button>
    <button class="px-3 py-1.5 text-xs   border rounded-lg hover:bg-muted/50 transition-colors">Redo</button>
    <button class="px-3 py-1.5 text-xs  border rounded-lg hover:bg-muted/50 transition-colors font-semibold">Clear</button>


  </div>

  <!-- Right: Export / Share / Import -->
  <div class="flex items-center gap-2">
    <button class="w-8 h-8 flex items-center justify-center rounded border border-[#2a3a50] text-[#8a9bb0] hover:text-amber-400 hover:border-amber-500/50 transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
      </svg>
    </button>
    <button class="w-8 h-8 flex items-center justify-center rounded border border-[#2a3a50] text-[#8a9bb0] hover:text-amber-400 hover:border-amber-500/50 transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.172 13.828a4 4 0 015.656 0l4 4a4 4 0 01-5.656 5.656l-1.1-1.1" />
      </svg>
    </button>
    <button class="w-8 h-8 flex items-center justify-center rounded border border-[#2a3a50] text-[#8a9bb0] hover:text-amber-400 hover:border-amber-500/50 transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
      </svg>
    </button>
  </div>
</header>