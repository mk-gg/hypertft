
# ── Riot Games API ────────────────────────────────────────────────
# Get your key at https://developer.riotgames.com
RIOT_API_KEY=RGAPI-your-key-here


# ── PostgreSQL ────────────────────────────────────────────────────
# Single libpq connection string. Tables and indexes (including the GIN
# index on comp unit arrays) are created automatically on first run.
#
# Local:    postgresql://postgres:postgres@localhost:5432/hypertft
# Railway:  copy the DATABASE_URL from the Postgres plugin's Variables tab
# Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hypertft


# ── Redis (optional) ──────────────────────────────────────────────
# Cache-aside layer for read-heavy API queries (tier list, patches, meta,
# unit roster). Leave unset to disable caching — the API then reads straight
# from PostgreSQL. The collector and aggregator flush this cache after a run.
#
# Local:   redis://localhost:6379/0
# Upstash: rediss://default:<password>@<host>.upstash.io:6379   (note: rediss, TLS)
# REDIS_URL=redis://localhost:6379/0

# Cache entry TTL in seconds. Optional — defaults to 3600 (1 hour) if unset.
# This is only a safety net: the collector/aggregator invalidate the cache on
# every run, so freshness is handled by invalidation, not expiry. Raise it to
# lean harder on the cache, lower it to bound staleness if a run ever fails.
# CACHE_TTL_SECONDS=3600


# ── Collector ─────────────────────────────────────────────────────
# How many NEW matches to download per collector run.
# The collector resumes from disk so re-runs are additive.
TARGET_MATCHES_PER_RUN=500

# Match history depth fetched per player (Riot API max is 20).
MATCHES_PER_PUUID=20

# Pages fetched per paginated division (each page ≈ 205 entries).
# Only applies to Diamond / Emerald / Platinum tiers.
SEED_PAGES=2

# ── Per-rank-group PUUID quotas ───────────────────────────────────
# Each group collects independently — ensures every rank is
# represented regardless of how large the higher tiers are.
#
# Default total per region = 450 PUUIDs
# (50 + 50 + 50 + 75 + 75 + 75 + 75)
#
# Tip: raise individual groups to skew toward a skill level.
# Tip: run multiple regions (--platforms na1 euw1 kr) instead of
#      raising quotas to get more diverse data efficiently.
#
QUOTA_CHALLENGER=50       # ~250 players available in NA
QUOTA_GRANDMASTER=50      # ~500 players available in NA
QUOTA_MASTER=50           # ~4000 players available in NA
QUOTA_DIAMOND=75          # Diamond I → IV combined
QUOTA_EMERALD=75          # Emerald I → IV combined
QUOTA_PLATINUM_HIGH=75    # Platinum I–II
QUOTA_PLATINUM_LOW=75     # Platinum III–IV


# ── Aggregator ────────────────────────────────────────────────────
# Jaccard similarity threshold for "superset" comp bucket.
# 0.60 = 60% of units must overlap to be counted as similar.
SUPER_THRESHOLD=0.60

# Minimum exact matches for a comp to appear in stats.
# Raise this to reduce noise when you have large datasets.
MIN_N_COMP=3

# Minimum appearances for a mutation/addition to surface.
MIN_N_MUTATION=2
MIN_N_ADDITION=2


# ── API ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated CORS origins. Use * for local dev only.
# In production set this to your actual frontend domain.
# CORS_ORIGINS=https://hypertft.net,https://www.hypertft.net
